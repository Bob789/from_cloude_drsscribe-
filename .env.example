# ========================================
# MedScribe AI - Environment Configuration
# Copy to .env and fill in values
# ========================================

# App
ENV_MODE=dev                          # dev / staging / prod
APP_NAME=MedScribe AI
APP_VERSION=0.1.0
DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medscribe
DB_USER=medscribe
DB_PASSWORD=changeme_db_password
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# JWT — HS256 (default) or RS256 (recommended for production)
# For HS256:
JWT_SECRET=changeme_jwt_secret_at_least_32_chars
# For RS256 (run: bash scripts/generate_rsa_keys.sh):
# JWT_ALGORITHM=RS256
# JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost/api/auth/google/callback

# MinIO / S3 (Audio Storage)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=changeme_minio_password
S3_BUCKET=medscribe-audio
S3_REGION=us-east-1
# MinIO KMS encryption at rest (32+ random bytes, base64 encoded)
MINIO_ENCRYPTION_KEY=changeme_generate_with_openssl_rand_base64_32

# OpenAI API (STT + LLM Summarization)
WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions
WHISPER_API_KEY=your_openai_api_key
WHISPER_MODEL=whisper-1
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=changeme_meilisearch_key

# Encryption (PII)
ENCRYPTION_KEY=changeme_32_byte_hex_key_here_00

# Sentry (Error Tracking)
SENTRY_DSN=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:80
