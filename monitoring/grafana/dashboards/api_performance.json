{
  "dashboard": {
    "title": "MedScribe API Performance",
    "panels": [
      {
        "title": "Request Rate",
        "type": "graph",
        "targets": [{"expr": "rate(http_requests_total[5m])"}]
      },
      {
        "title": "Request Latency (p95)",
        "type": "graph",
        "targets": [{"expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))"}]
      },
      {
        "title": "Active Requests",
        "type": "gauge",
        "targets": [{"expr": "http_active_requests"}]
      },
      {
        "title": "Error Rate",
        "type": "graph",
        "targets": [{"expr": "rate(error_total[5m])"}]
      },
      {
        "title": "STT Processing Duration",
        "type": "graph",
        "targets": [{"expr": "histogram_quantile(0.95, rate(stt_processing_seconds_bucket[5m]))"}]
      },
      {
        "title": "LLM Processing Duration",
        "type": "graph",
        "targets": [{"expr": "histogram_quantile(0.95, rate(llm_processing_seconds_bucket[5m]))"}]
      }
    ]
  }
}
