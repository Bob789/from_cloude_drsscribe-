FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ARG DEV_TOOLS_URL=http://dev-tools:8090
ENV DEV_TOOLS_URL=$DEV_TOOLS_URL
ARG NEXT_PUBLIC_FEATURE_FORUM=false
ENV NEXT_PUBLIC_FEATURE_FORUM=$NEXT_PUBLIC_FEATURE_FORUM
ARG NEXT_PUBLIC_FEATURE_EXPERTS=false
ENV NEXT_PUBLIC_FEATURE_EXPERTS=$NEXT_PUBLIC_FEATURE_EXPERTS
ARG NEXT_PUBLIC_FEATURE_PRODUCT=false
ENV NEXT_PUBLIC_FEATURE_PRODUCT=$NEXT_PUBLIC_FEATURE_PRODUCT
RUN npm run build
EXPOSE 3000
CMD ["node_modules/.bin/next", "start", "-p", "3000"]
